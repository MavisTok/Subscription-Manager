#!/bin/bash
# ============================================================
#  Pre-commit hook: 自动 bump sub-manager.sh 的版本号
#
#  规则 (Semantic Versioning 2.0.0 / Conventional Commits):
#    MAJOR.MINOR.PATCH
#    ┌─────────────────────────────────────────────────────┐
#    │ 自动检测（按优先级）:                                │
#    │  1. 环境变量 BUMP=major/minor/patch（最高优先）      │
#    │  2. commit -m 消息前缀 (Conventional Commits):       │
#    │       feat:/feature:/新增  → MINOR (+1, patch→0)    │
#    │       fix:/修复/bugfix     → PATCH (+1)              │
#    │       break:/breaking      → MAJOR (+1, minor/patch→0)│
#    │       其他前缀             → PATCH (+1)              │
#    │  3. 无 -m 消息（交互式提交） → PATCH (+1, 默认)     │
#    │                                                       │
#    │ 手动修改版本号后自动跳过 bump（优先尊重手动版本）    │
#    └─────────────────────────────────────────────────────┘
#
#  示例:
#    git commit -m "fix: 修复推送失败"           → PATCH
#    git commit -m "feat: 新增 Telegram Bot"     → MINOR
#    BUMP=major git commit -m "breaking: 重构API"→ MAJOR
# ============================================================

SCRIPT="sub-manager.sh"

# 当 sub-manager.sh 或任意 lib/*.sh 被 staged 时才处理
if ! git diff --cached --name-only | grep -qE "^(${SCRIPT}|lib/.+\.sh)$"; then
    exit 0
fi

# 读取当前版本
current=$(grep -m1 "^readonly VERSION=" "$SCRIPT" 2>/dev/null | cut -d'"' -f2)
if [[ -z "$current" ]]; then
    echo "[hook] 未找到版本号，跳过自动 bump"
    exit 0
fi

# 检查版本是否已被手动修改（与 HEAD 对比）→ 跳过自动 bump
head_ver=$(git show HEAD:"$SCRIPT" 2>/dev/null | grep -m1 "^readonly VERSION=" | cut -d'"' -f2)
if [[ -n "$head_ver" && "$current" != "$head_ver" ]]; then
    echo "[hook] 版本已手动修改: ${head_ver} → ${current}，跳过自动 bump"
    exit 0
fi

# 解析版本号
IFS='.' read -r major minor patch <<< "$current"
if ! [[ "$major" =~ ^[0-9]+$ && "$minor" =~ ^[0-9]+$ && "$patch" =~ ^[0-9]+$ ]]; then
    echo "[hook] 版本格式不符合 SemVer，跳过自动 bump"
    exit 0
fi

# ── 确定 bump 类型 ────────────────────────────────────────
bump_type="patch"  # 默认

# 1. 环境变量优先
if [[ -n "${BUMP:-}" ]]; then
    bump_type=$(echo "$BUMP" | tr '[:upper:]' '[:lower:]')
else
    # 2. 尝试读取 commit message（git commit -m 时在 pre-commit 前已写入）
    git_dir=$(git rev-parse --git-dir 2>/dev/null)
    commit_msg=""
    [[ -f "${git_dir}/COMMIT_EDITMSG" ]] && commit_msg=$(head -1 "${git_dir}/COMMIT_EDITMSG" 2>/dev/null)

    if [[ -n "$commit_msg" ]]; then
        if echo "$commit_msg" | grep -qiE "^(feat|feature|新增|add feature)(\(.+\))?[!:]"; then
            bump_type="minor"
        elif echo "$commit_msg" | grep -qiE "^(break|breaking|BREAKING[_ -]CHANGE)(\(.+\))?[!:]"; then
            bump_type="major"
        elif echo "$commit_msg" | grep -qiE "^(fix|修复|bugfix|hotfix|patch)(\(.+\))?[!:]"; then
            bump_type="patch"
        fi
    fi
fi

# ── 执行 bump ─────────────────────────────────────────────
case "$bump_type" in
    major)
        major=$(( major + 1 ))
        minor=0
        patch=0
        label="MAJOR"
        ;;
    minor|feat|feature)
        minor=$(( minor + 1 ))
        patch=0
        label="MINOR"
        ;;
    *)  # patch (default)
        patch=$(( patch + 1 ))
        label="PATCH"
        ;;
esac

new_version="${major}.${minor}.${patch}"

# 跨平台 sed -i
if [[ "$(uname -s)" == "Darwin" ]]; then
    sed -i '' "s/readonly VERSION=\"${current}\"/readonly VERSION=\"${new_version}\"/" "$SCRIPT"
else
    sed -i "s/readonly VERSION=\"${current}\"/readonly VERSION=\"${new_version}\"/" "$SCRIPT"
fi

# 重新暂存
git add "$SCRIPT"

echo "[hook] 版本自动 bump: ${current} → ${new_version} (${label})"
