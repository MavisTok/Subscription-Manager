#!/bin/bash
# 将当前 sub-manager.sh 版本号追加到 commit 消息第一行末尾
# 当 sub-manager.sh 或任意 lib/*.sh 被 staged 时生效

SCRIPT="sub-manager.sh"
COMMIT_MSG_FILE="$1"

git diff --cached --name-only | grep -qE "^(${SCRIPT}|lib/.+\.sh)$" || exit 0

# 读取版本（pre-commit 已 bump，这里读的是 bump 后的值）
ver=$(grep -m1 "^readonly VERSION=" "$SCRIPT" 2>/dev/null | cut -d'"' -f2)
[[ -z "$ver" ]] && exit 0

# 如果消息里已有版本标记则跳过
grep -qF "[v${ver}]" "$COMMIT_MSG_FILE" 2>/dev/null && exit 0

# 在第一行末尾追加版本号（awk 跨平台兼容）
awk -v ver="[v${ver}]" 'NR==1{print $0" "ver; next}{print}' \
    "$COMMIT_MSG_FILE" > "${COMMIT_MSG_FILE}.tmp" \
    && mv "${COMMIT_MSG_FILE}.tmp" "$COMMIT_MSG_FILE"
